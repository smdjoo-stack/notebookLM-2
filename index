<!DOCTYPE html>
<html lang="ko" data-theme="light">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>목회자를 위한 노트북LM 마스터 가이드</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
<style>
/* ── CMDSPACE Design System v4.3 ─────────────────────────── */
:root {
  --cmds-green:       #134538;
  --cmds-green-light: #1e6350;
  --cmds-pink:        #E985A2;
  --cmds-pink-dark:   #d4607e;

  --bg:       #FAFAF8;
  --bg-2:     #F2F0EB;
  --bg-3:     #E8E5DE;
  --ink:      #111111;
  --ink-2:    #3A3A3A;
  --ink-3:    #787878;
  --border:   rgba(0,0,0,0.08);
  --border-2: rgba(0,0,0,0.14);

  --accent:       var(--cmds-green);
  --accent-fg:    #FFFFFF;
  --accent-soft:  rgba(19, 69, 56, 0.07);
  --accent-soft2: rgba(19, 69, 56, 0.14);

  --font-sans:    "Pretendard Variable", "Pretendard", -apple-system, "SF Pro Text", system-ui, sans-serif;
  --font-display: "SF Pro Display", "Pretendard Variable", "Pretendard", sans-serif;
  --font-mono:    "SF Mono", "JetBrains Mono", ui-monospace, monospace;

  --sidebar-w: 260px;
  --content-max: 820px;
  --radius: 10px;
  --radius-lg: 16px;

  --density-pad: 88px;
  --section-gap: 120px;
}
[data-theme="dark"] {
  --bg:       #111111;
  --bg-2:     #1A1A1A;
  --bg-3:     #242424;
  --ink:      #F0EDE8;
  --ink-2:    #B8B3AC;
  --ink-3:    #6E6B66;
  --border:   rgba(255,255,255,0.07);
  --border-2: rgba(255,255,255,0.12);

  --accent:      var(--cmds-pink);
  --accent-fg:   #1B1B1B;
  --accent-soft:  rgba(233, 133, 162, 0.10);
  --accent-soft2: rgba(233, 133, 162, 0.18);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; font-size: 16px; }

body {
  font-family: var(--font-sans);
  background: var(--bg);
  color: var(--ink);
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
  transition: background 0.2s, color 0.2s;
}

a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }

/* ── Layout ────────────────────────────────────────────── */
.shell {
  display: flex;
  min-height: 100vh;
}

/* ── Sidebar ───────────────────────────────────────────── */
.sidebar {
  position: fixed;
  top: 0; left: 0;
  width: var(--sidebar-w);
  height: 100vh;
  overflow-y: auto;
  border-right: 1px solid var(--border);
  background: var(--bg);
  display: flex;
  flex-direction: column;
  z-index: 100;
  padding: 32px 0 40px;
}

.sidebar-brand {
  padding: 0 24px 28px;
  border-bottom: 1px solid var(--border);
}
.brand-seal {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: var(--accent);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-size: 16px; font-weight: 700;
  color: var(--accent-fg);
  margin-bottom: 10px;
  letter-spacing: -0.5px;
}
.brand-title {
  font-size: 13px; font-weight: 600;
  color: var(--ink);
  line-height: 1.3;
  letter-spacing: -0.2px;
}
.brand-sub {
  font-size: 10px;
  font-family: var(--font-mono);
  color: var(--ink-3);
  margin-top: 3px;
  letter-spacing: 0.08em;
}

.sidebar-nav {
  flex: 1;
  padding: 20px 0;
}
.sidebar-nav a {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 24px;
  font-size: 13px; color: var(--ink-2);
  transition: color 0.15s, background 0.15s;
  text-decoration: none;
  border-left: 2px solid transparent;
}
.sidebar-nav a:hover { color: var(--ink); background: var(--accent-soft); }
.sidebar-nav a.active {
  color: var(--accent);
  font-weight: 600;
  border-left-color: var(--accent);
  background: var(--accent-soft);
}
.nav-num {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-3);
  min-width: 20px;
}
.sidebar-nav a.active .nav-num { color: var(--accent); opacity: 0.7; }

.sidebar-foot {
  padding: 20px 24px 0;
  border-top: 1px solid var(--border);
  font-size: 11px;
  color: var(--ink-3);
  line-height: 1.7;
}

.theme-btn {
  display: flex; align-items: center; gap: 8px;
  margin: 16px 24px 0;
  padding: 8px 14px;
  border: 1px solid var(--border-2);
  border-radius: 20px;
  background: transparent;
  font-family: var(--font-sans);
  font-size: 12px; color: var(--ink-2);
  cursor: pointer;
  transition: border-color 0.15s, color 0.15s;
}
.theme-btn:hover { border-color: var(--accent); color: var(--accent); }

/* ── Main Content ──────────────────────────────────────── */
.main {
  margin-left: var(--sidebar-w);
  flex: 1;
  min-width: 0;
}

/* ── Hero ──────────────────────────────────────────────── */
.hero {
  padding: 96px var(--density-pad) 80px;
  border-bottom: 1px solid var(--border);
}
.hero-eyebrow {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--accent);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 20px;
}
.hero h1 {
  font-family: var(--font-display);
  font-size: clamp(36px, 5vw, 56px);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -1.5px;
  color: var(--ink);
  max-width: 680px;
  margin-bottom: 24px;
}
.hero h1 em {
  font-style: normal;
  color: var(--accent);
}
.hero-sub {
  font-size: 17px;
  color: var(--ink-2);
  max-width: 560px;
  line-height: 1.75;
  margin-bottom: 32px;
}
.hero-chips {
  display: flex; flex-wrap: wrap; gap: 8px;
  margin-bottom: 28px;
}
.chip {
  display: inline-flex; align-items: center;
  height: 28px;
  padding: 0 12px;
  border-radius: 14px;
  border: 1px solid var(--border-2);
  font-size: 12px; font-weight: 500;
  color: var(--ink-2);
  background: var(--bg-2);
}
.hero-meta {
  display: flex; align-items: center; gap: 10px;
  flex-wrap: wrap;
  font-size: 13px; color: var(--ink-3);
}
.hero-meta b { color: var(--ink-2); font-weight: 600; }
.dot { opacity: 0.4; }

.hero-grid {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 48px;
  align-items: start;
  max-width: var(--content-max);
}
.hero-card {
  max-width: 300px;
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 28px;
  margin-top: 8px;
}
.quote-mark {
  font-size: 48px;
  line-height: 1;
  color: var(--accent);
  font-family: Georgia, serif;
  margin-bottom: 8px;
  opacity: 0.6;
}
.pull {
  font-size: 14px;
  color: var(--ink-2);
  line-height: 1.75;
  margin-bottom: 12px;
}
.attrib {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-3);
  letter-spacing: 0.05em;
}

/* ── Section ───────────────────────────────────────────── */
.page-section {
  padding: 96px var(--density-pad);
  border-bottom: 1px solid var(--border);
  max-width: calc(var(--content-max) + var(--density-pad) * 2);
}
.section-eyebrow {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--accent);
  letter-spacing: 0.16em;
  text-transform: uppercase;
  margin-bottom: 16px;
  display: flex; align-items: center; gap: 8px;
}
.section-eyebrow::before {
  content: "";
  display: inline-block;
  width: 16px; height: 1px;
  background: var(--accent);
}
.page-section h2 {
  font-family: var(--font-display);
  font-size: clamp(26px, 3.5vw, 38px);
  font-weight: 700;
  letter-spacing: -1px;
  line-height: 1.2;
  color: var(--ink);
  margin-bottom: 20px;
  max-width: 600px;
}
.lede {
  font-size: 16px;
  color: var(--ink-2);
  max-width: 640px;
  line-height: 1.8;
  margin-bottom: 0;
}

/* ── Cards ─────────────────────────────────────────────── */
.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}
.grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}

.card {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
  transition: border-color 0.2s;
}
.card:hover { border-color: var(--accent); }
.card .num {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--accent);
  letter-spacing: 0.12em;
  margin-bottom: 12px;
}
.card h3 {
  font-size: 15px; font-weight: 700;
  color: var(--ink);
  margin-bottom: 8px;
  letter-spacing: -0.3px;
  line-height: 1.4;
}
.card p {
  font-size: 13px;
  color: var(--ink-2);
  line-height: 1.7;
}

/* ── Stat Strip ────────────────────────────────────────── */
.stat-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-top: 48px;
}
.stat {
  padding: 28px 20px;
  border-right: 1px solid var(--border);
  text-align: center;
}
.stat:last-child { border-right: none; }
.stat .v {
  font-family: var(--font-display);
  font-size: 32px; font-weight: 800;
  color: var(--ink);
  letter-spacing: -1px;
  line-height: 1;
  margin-bottom: 6px;
}
.stat .unit {
  font-size: 16px; font-weight: 500;
}
.stat .k {
  font-size: 11px; color: var(--ink-3);
  line-height: 1.4;
}

/* ── Principle List ────────────────────────────────────── */
.principle-list {
  display: flex; flex-direction: column; gap: 0;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-top: 40px;
}
.principle {
  display: flex; gap: 24px;
  padding: 28px 28px;
  border-bottom: 1px solid var(--border);
  transition: background 0.15s;
}
.principle:last-child { border-bottom: none; }
.principle:hover { background: var(--accent-soft); }
.marker {
  font-family: var(--font-display);
  font-size: 22px; font-weight: 800;
  color: var(--accent);
  min-width: 36px;
  line-height: 1.2;
  opacity: 0.7;
}
.principle h4 {
  font-size: 15px; font-weight: 700;
  color: var(--ink);
  margin-bottom: 6px;
  letter-spacing: -0.3px;
}
.principle p {
  font-size: 13.5px;
  color: var(--ink-2);
  line-height: 1.75;
}

/* ── Caveat ────────────────────────────────────────────── */
.caveat {
  background: var(--accent-soft);
  border: 1px solid var(--accent-soft2);
  border-radius: var(--radius);
  padding: 20px 24px;
  margin-top: 32px;
}
.caveat .label {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--accent);
  letter-spacing: 0.15em;
  margin-bottom: 8px;
}
.caveat p {
  font-size: 13px;
  color: var(--ink-2);
  line-height: 1.75;
}

/* ── Tabs ──────────────────────────────────────────────── */
.tabs-shell {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 0;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-top: 40px;
}
.tab-list {
  border-right: 1px solid var(--border);
  background: var(--bg-2);
}
.tab-btn {
  display: flex; align-items: flex-start; gap: 12px;
  width: 100%;
  padding: 18px 20px;
  border: none; border-bottom: 1px solid var(--border);
  background: transparent;
  text-align: left;
  cursor: pointer;
  transition: background 0.15s;
  color: var(--ink-2);
  font-family: var(--font-sans);
}
.tab-btn:last-child { border-bottom: none; }
.tab-btn:hover { background: var(--bg-3); color: var(--ink); }
.tab-btn.active {
  background: var(--bg);
  color: var(--ink);
  border-right: 2px solid var(--accent);
  margin-right: -1px;
}
.tab-num {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--accent);
  min-width: 16px;
  margin-top: 2px;
}
.tab-name { font-size: 13px; font-weight: 600; line-height: 1.3; }
.tab-sub { font-size: 11px; color: var(--ink-3); margin-top: 2px; }
.tab-body {
  padding: 36px 36px;
  display: none;
}
.tab-body.active { display: block; }
.tab-eyebrow {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--accent);
  letter-spacing: 0.12em;
  margin-bottom: 12px;
}
.tab-body h3 {
  font-size: 20px; font-weight: 700;
  letter-spacing: -0.5px;
  margin-bottom: 12px;
  color: var(--ink);
}
.tab-body p { font-size: 14px; color: var(--ink-2); line-height: 1.8; margin-bottom: 14px; }
.tab-body ul { padding-left: 0; list-style: none; display: flex; flex-direction: column; gap: 8px; }
.tab-body li {
  display: flex; gap: 10px;
  font-size: 13px; color: var(--ink-2); line-height: 1.7;
}
.tab-body li::before {
  content: "→";
  color: var(--accent);
  min-width: 14px;
  font-size: 12px;
  margin-top: 2px;
}
.use-tag {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--accent-fg);
  background: var(--accent);
  padding: 2px 8px;
  border-radius: 4px;
  letter-spacing: 0.08em;
  margin-right: 8px;
}

/* ── Timeline ──────────────────────────────────────────── */
.timeline {
  display: flex; flex-direction: column; gap: 0;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-top: 32px;
}
.tl-item {
  display: grid;
  grid-template-columns: 56px 180px 1fr;
  gap: 0;
  border-bottom: 1px solid var(--border);
}
.tl-item:last-child { border-bottom: none; }
.tl-num {
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-size: 24px; font-weight: 800;
  color: var(--accent);
  background: var(--accent-soft);
  border-right: 1px solid var(--border);
  opacity: 0.7;
}
.tl-title {
  padding: 24px 20px;
  border-right: 1px solid var(--border);
  background: var(--bg-2);
}
.tl-title .meta {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--ink-3);
  letter-spacing: 0.12em;
  margin-bottom: 6px;
}
.tl-title h3 {
  font-size: 14px; font-weight: 700;
  color: var(--ink);
  line-height: 1.35;
  letter-spacing: -0.2px;
}
.tl-body {
  padding: 24px 24px;
  font-size: 13.5px;
  color: var(--ink-2);
  line-height: 1.75;
}
.tl-body code {
  font-family: var(--font-mono);
  font-size: 11px;
  background: var(--bg-3);
  padding: 2px 6px;
  border-radius: 4px;
  color: var(--accent);
}

/* ── Use Case ──────────────────────────────────────────── */
.usecase {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: border-color 0.2s;
}
.usecase:hover { border-color: var(--accent); }
.usecase-art {
  height: 120px;
  background: var(--accent-soft2);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-size: 13px; font-weight: 700;
  color: var(--accent);
  letter-spacing: 0.05em;
  border-bottom: 1px solid var(--border);
}
.usecase-body { padding: 24px; }
.usecase-body .role {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--accent);
  letter-spacing: 0.14em;
  margin-bottom: 8px;
}
.usecase-body h3 {
  font-size: 17px; font-weight: 700;
  letter-spacing: -0.4px;
  margin-bottom: 10px;
  color: var(--ink);
  line-height: 1.3;
}
.usecase-body > p {
  font-size: 13px; color: var(--ink-2); line-height: 1.7; margin-bottom: 16px;
}
.usecase-steps {
  list-style: none;
  display: flex; flex-direction: column; gap: 10px;
}
.usecase-steps li {
  display: flex; gap: 12px;
  font-size: 13px; color: var(--ink-2); line-height: 1.65;
}
.usecase-steps li b {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--accent);
  min-width: 22px;
  margin-top: 2px;
  font-weight: 700;
}

/* ── Prompts ───────────────────────────────────────────── */
.prompt-filter {
  display: flex; flex-wrap: wrap; gap: 8px;
  margin: 32px 0 28px;
}
.filter-btn {
  height: 32px;
  padding: 0 16px;
  border: 1px solid var(--border-2);
  border-radius: 16px;
  background: transparent;
  font-family: var(--font-sans);
  font-size: 13px; color: var(--ink-2);
  cursor: pointer;
  transition: all 0.15s;
}
.filter-btn:hover { border-color: var(--accent); color: var(--accent); }
.filter-btn.active {
  background: var(--accent);
  border-color: var(--accent);
  color: var(--accent-fg);
}
.prompt-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
}
.prompt-card {
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 22px;
  background: var(--bg-2);
  transition: border-color 0.2s;
}
.prompt-card:hover { border-color: var(--accent); }
.prompt-head {
  margin-bottom: 8px;
}
.prompt-tag {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--accent);
  letter-spacing: 0.12em;
  text-transform: uppercase;
}
.prompt-title {
  font-size: 14px; font-weight: 700;
  color: var(--ink);
  margin-bottom: 10px;
  letter-spacing: -0.3px;
  line-height: 1.35;
}
.prompt-body {
  font-size: 12.5px;
  color: var(--ink-2);
  line-height: 1.75;
  padding: 12px 14px;
  background: var(--bg-3);
  border-radius: 8px;
  font-family: var(--font-mono);
  margin-bottom: 12px;
  white-space: pre-wrap;
}
.prompt-foot {
  display: flex; align-items: center; justify-content: space-between;
  gap: 12px;
}
.prompt-note {
  font-size: 11px;
  color: var(--ink-3);
  line-height: 1.5;
  flex: 1;
}
.copy-btn {
  flex-shrink: 0;
  height: 28px; padding: 0 14px;
  border: 1px solid var(--border-2);
  border-radius: 14px;
  background: transparent;
  font-family: var(--font-sans);
  font-size: 11px; font-weight: 600;
  color: var(--ink-2);
  cursor: pointer;
  transition: all 0.15s;
}
.copy-btn:hover { border-color: var(--accent); color: var(--accent); }
.copy-btn.copied {
  background: var(--accent);
  border-color: var(--accent);
  color: var(--accent-fg);
}

/* ── FAQ ───────────────────────────────────────────────── */
.faq {
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-top: 40px;
}
.faq-item {
  border-bottom: 1px solid var(--border);
}
.faq-item:last-child { border-bottom: none; }
.faq-q {
  display: flex; align-items: center; justify-content: space-between; gap: 16px;
  width: 100%;
  padding: 22px 28px;
  background: transparent;
  border: none;
  text-align: left;
  font-family: var(--font-sans);
  font-size: 15px; font-weight: 600;
  color: var(--ink);
  cursor: pointer;
  transition: background 0.15s;
  line-height: 1.45;
}
.faq-q:hover { background: var(--accent-soft); }
.faq-icon {
  font-size: 18px;
  color: var(--ink-3);
  transition: transform 0.2s;
  min-width: 18px;
}
.faq-item.open .faq-icon { transform: rotate(45deg); color: var(--accent); }
.faq-a {
  display: none;
  padding: 0 28px 24px;
  font-size: 14px;
  color: var(--ink-2);
  line-height: 1.8;
  border-top: 1px solid var(--border);
  background: var(--accent-soft);
}
.faq-item.open .faq-a { display: block; padding-top: 20px; }

/* ── Footer ────────────────────────────────────────────── */
footer {
  padding: 64px var(--density-pad) 80px;
  border-top: 1px solid var(--border);
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 48px;
  align-items: start;
}
footer h4 {
  font-size: 13px; font-weight: 700;
  color: var(--ink);
  margin-bottom: 16px;
  letter-spacing: -0.2px;
}
.foot-blessing {
  font-size: 17px;
  color: var(--ink-2);
  line-height: 1.8;
  font-style: italic;
}
footer ul {
  list-style: none;
  display: flex; flex-direction: column; gap: 8px;
}
footer li { font-size: 13px; }
footer li a { color: var(--ink-2); }
footer li a:hover { color: var(--accent); }
.foot-bottom {
  grid-column: 1 / -1;
  padding-top: 28px;
  border-top: 1px solid var(--border);
  display: flex; justify-content: space-between;
  font-size: 11px; color: var(--ink-3);
  font-family: var(--font-mono);
}

/* ── Responsive ────────────────────────────────────────── */
@media (max-width: 1100px) {
  :root { --sidebar-w: 220px; --density-pad: 48px; }
  .grid-4 { grid-template-columns: repeat(2, 1fr); }
  .stat-strip { grid-template-columns: repeat(2, 1fr); }
  .stat:nth-child(2) { border-right: none; }
  .tabs-shell { grid-template-columns: 1fr; }
  .tab-list { display: flex; overflow-x: auto; border-right: none; border-bottom: 1px solid var(--border); }
  .tab-btn { border-right: 1px solid var(--border); border-bottom: none; min-width: 140px; }
  .tab-btn.active { border-right-color: var(--border); border-bottom: 2px solid var(--accent); margin-right: 0; margin-bottom: -1px; }
  .tl-item { grid-template-columns: 44px 1fr; }
  .tl-title { border-right: none; border-bottom: 1px solid var(--border); grid-column: 2; }
  .tl-body { grid-column: 2; }
  footer { grid-template-columns: 1fr 1fr; }
  footer > div:first-child { grid-column: 1 / -1; }
}
@media (max-width: 768px) {
  :root { --sidebar-w: 0px; --density-pad: 24px; }
  .sidebar { transform: translateX(-100%); }
  .sidebar.open { transform: translateX(0); box-shadow: 0 0 40px rgba(0,0,0,0.15); }
  .main { margin-left: 0; }
  .hero-grid { grid-template-columns: 1fr; }
  .hero-card { max-width: 100%; }
  .grid-3, .grid-2, .grid-4 { grid-template-columns: 1fr; }
  .stat-strip { grid-template-columns: repeat(2, 1fr); }
  .prompt-grid { grid-template-columns: 1fr; }
  .tl-item { grid-template-columns: 44px 1fr; }
  footer { grid-template-columns: 1fr; gap: 32px; }
  .foot-bottom { flex-direction: column; gap: 8px; }
  .mobile-menu-btn { display: flex; }
}

.mobile-menu-btn {
